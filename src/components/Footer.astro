---
// Footer and CTA section
import { TRANSLATIONS, type Language } from '../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const t = TRANSLATIONS[lang];
---

<footer class="w-full bg-zinc-950/40 backdrop-blur-md pt-24 pb-12 border-t border-white/5 text-center relative overflow-hidden">
  <!-- Interactive Background grid pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff03_1px,transparent_1px),linear-gradient(to_bottom,#ffffff03_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-40"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4">
    <div class="text-6xl mb-6 animate-float" style="animation-duration: 4s;">🚀</div>
    <h2 class="text-4xl md:text-5xl font-black tracking-tight text-white mb-6">
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-cta">{t.footerTitle}</span>
    </h2>
    
    <p class="text-lg md:text-xl text-zinc-350 mb-12 max-w-2xl mx-auto leading-relaxed text-zinc-350">
      {t.footerDesc}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a href="https://github.com/nguyenak95/smart-infographic" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-4 btn-shimmer hover:opacity-90 text-white font-bold rounded-full transition-all duration-300 text-lg shadow-[0_0_25px_rgba(14,165,233,0.3)] hover:shadow-[0_0_35px_rgba(14,165,233,0.5)] flex items-center justify-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        {t.footerGetOnGithub}
      </a>
      <a href="#gallery" class="w-full sm:w-auto px-8 py-4 bg-zinc-950/60 hover:bg-zinc-900/80 text-white font-bold rounded-full transition-all duration-300 text-lg border border-white/10 hover:border-white/20">
        {t.footerExploreTemplates}
      </a>
    </div>

    {/* Contribution Call-to-Action note */}
    <p class="text-xs text-zinc-500 mb-12 max-w-lg mx-auto leading-relaxed border-t border-white/5 pt-8">
      {t.footerContributeNote}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 text-sm md:text-base font-semibold text-slate-400">
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        {t.footerOpenSource}
      </span>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        {t.footerAiCompatible}
      </span>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        {t.footerFree}
      </span>
    </div>
  </div>
</footer>
