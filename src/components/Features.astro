---
// Features section component
---

<section id="features" class="w-full px-4 md:px-8 mx-auto py-24 md:py-32">
  <div class="text-center mb-16 md:mb-24">
    <h2 class="text-4xl md:text-5xl font-black tracking-tight text-foreground mb-6">
      Modular Templates <br class="md:hidden" /> for Every Scenario
    </h2>
    <p class="text-lg md:text-xl text-foreground/70 max-w-2xl mx-auto">
      Combine domains, structures, and styles to generate the exact infographic you need.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 w-full">
    <!-- Card 1 -->
    <div class="bg-zinc-900/50 rounded-3xl p-8 lg:p-10 border border-zinc-800 shadow-xl shadow-black/50 hover:-translate-y-2 transition-all duration-300 group">
      <div class="w-14 h-14 bg-zinc-800 rounded-2xl flex items-center justify-center mb-6 border border-zinc-700 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M3 15h6"/><path d="M3 18h6"/><path d="M3 12h6"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-foreground mb-4">Domain Contexts</h3>
      <p class="text-foreground/70 leading-relaxed mb-8">
        Pre-written tone and knowledge instructions optimized for specific industries and use cases.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">SaaS</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">E-commerce</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Healthcare</span>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="bg-zinc-900/50 rounded-3xl p-8 lg:p-10 border border-zinc-800 shadow-xl shadow-black/50 hover:-translate-y-2 transition-all duration-300 group">
      <div class="w-14 h-14 bg-zinc-800 rounded-2xl flex items-center justify-center mb-6 border border-zinc-700 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-foreground mb-4">Structural Layouts</h3>
      <p class="text-foreground/70 leading-relaxed mb-8">
        Blueprint instructions that define the information hierarchy and visual flow of the data.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Timeline</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Flowchart</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Comparison</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Process</span>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="bg-zinc-900/50 rounded-3xl p-8 lg:p-10 border border-zinc-800 shadow-xl shadow-black/50 hover:-translate-y-2 transition-all duration-300 group">
      <div class="w-14 h-14 bg-zinc-800 rounded-2xl flex items-center justify-center mb-6 border border-zinc-700 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-foreground mb-4">Visual Styles</h3>
      <p class="text-foreground/70 leading-relaxed mb-8">
        Aesthetic guidelines and prompt formatting rules that dictate the final visual output.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Glassmorphism</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Neumorphism</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Minimalism</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Isometric</span>
      </div>
    </div>

    <!-- Card 4 -->
    <div class="bg-zinc-900/50 rounded-3xl p-8 lg:p-10 border border-zinc-800 shadow-xl shadow-black/50 hover:-translate-y-2 transition-all duration-300 group">
      <div class="w-14 h-14 bg-zinc-800 rounded-2xl flex items-center justify-center mb-6 border border-zinc-700 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-foreground mb-4">Validation & Gathering</h3>
      <p class="text-foreground/70 leading-relaxed mb-8">
        Intelligent prompting that stops to ask for missing information before generating.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Interactive</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Fallback</span>
        <span class="px-3 py-1 bg-sky-900/30 text-sky-400 text-sm font-medium rounded-full border border-sky-800/50">Safety checks</span>
      </div>
    </div>
  </div>
</section>
