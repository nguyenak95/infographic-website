---
// How It Works section component
const steps = [
  {
    num: "1",
    title: "Your Prompt",
    desc: 'You provide a simple request, e.g., "Make an infographic about our new SaaS launch timeline for the Q4 board meeting."',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`
  },
  {
    num: "2",
    title: "AI Reasoning",
    desc: "The agent parses your intent instantly. It maps your request to Product: SaaS, Structure: Timeline, Style: Glassmorphism.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`
  },
  {
    num: "3",
    title: "Data Gathering",
    desc: "Identifying missing required context, the agent prompts you for missing specifics: exact dates, milestones, and data points.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 21v-5h5"/></svg>`
  },
  {
    num: "4",
    title: "Construct Prompt",
    desc: "Under the hood, it combines modular context, structure, and style JSON templates into one massive instruction prompt.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg>`
  },
  {
    num: "5",
    title: "CLI Execution",
    desc: "Seamless execution occurs via `nlm notebook create` and `nlm infographic create` powered directly by NotebookLM limits.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="m7 11 2-2-2-2"/><path d="M11 13h4"/></svg>`
  },
  {
    num: "6",
    title: "Final Result",
    desc: "The generated infographic is saved locally, matching the requested aesthetic and perfectly structuring your data.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>`
  }
];
---

<section id="how-it-works" class="w-full bg-slate-900 border-y border-slate-800 py-24 md:py-32 relative overflow-hidden">
  <!-- Interactive Background grid pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-20"></div>

  <div class="relative w-full max-w-7xl mx-auto px-4 md:px-8">
    <div class="text-center mb-16 md:mb-24">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-white mb-6">
        How It Works
      </h2>
      <p class="text-lg md:text-xl text-slate-300 max-w-2xl mx-auto">
        From initial prompt to a complete NotebookLM infographic in 6 intelligent steps.
      </p>
    </div>

    <!-- Stepper Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12 relative z-10">
      {steps.map((step, idx) => (
        <div class="bg-slate-800/50 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-8 hover:bg-slate-800 transition-colors duration-300 relative group">
          <div class="absolute -top-6 -right-6 text-8xl font-black text-slate-800/30 group-hover:text-primary/10 transition-colors duration-300 pointer-events-none select-none">
            {step.num}
          </div>
          <div class="w-12 h-12 bg-slate-900 rounded-xl flex items-center justify-center mb-6 border border-slate-700 group-hover:bg-primary group-hover:border-primary transition-all duration-300 shadow-xl shadow-black/20" set:html={step.icon} />
          
          <h3 class="text-xl font-bold text-white mb-3 flex items-center gap-3">
            <span class="text-primary">0{step.num}</span> {step.title}
          </h3>
          <p class="text-slate-400 leading-relaxed text-sm md:text-base">
            {step.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
