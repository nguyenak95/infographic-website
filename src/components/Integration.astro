---
// Developer Quick Start & Agent Integration Section
import { TRANSLATIONS, type Language } from '../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const t = TRANSLATIONS[lang];

const command = "npx skills add nguyenak95/smart-infographic --all";
---

<section id="integration" class="w-full px-4 md:px-8 mx-auto py-24 md:py-32 relative overflow-hidden">
  <!-- Dynamic ambient blur backdrop -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="text-center mb-16 md:mb-20 relative z-10">
    <span class="bg-primary/10 text-primary px-3.5 py-1 rounded-full border border-primary/20 text-xs font-black uppercase tracking-wider mb-4 inline-block">
      Quick Start
    </span>
    <h2 class="text-4xl md:text-5xl font-black tracking-tight text-foreground mb-6">
      {t.integrationTitle}
    </h2>
    <p class="text-lg md:text-xl text-foreground/70 max-w-2xl mx-auto">
      {t.integrationDesc}
    </p>
  </div>

  <div class="max-w-4xl mx-auto space-y-12 relative z-10">
    
    {/* Copiable installation bash box (Wow Style C) */}
    <div class="glass-premium cursor-glow-border rounded-3xl p-6 md:p-8 border border-white/5 shadow-2xl flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex-1 text-left w-full">
        <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest block mb-2">Terminal Installation</span>
        <div class="bg-zinc-950/80 border border-white/5 rounded-2xl p-4 font-mono text-sm text-primary flex items-center overflow-x-auto whitespace-nowrap custom-scrollbar">
          <span class="text-zinc-500 mr-3 shrink-0">$</span>
          <code id="install-command-text" class="text-zinc-200 select-all">{command}</code>
        </div>
      </div>
      
      <button
        id="copy-install-btn"
        type="button"
        class="w-full md:w-auto px-6 py-4 btn-shimmer hover:opacity-90 text-white font-bold rounded-2xl transition-all duration-200 shadow-[0_0_20px_rgba(14,165,233,0.3)] shrink-0 flex items-center justify-center gap-2 cursor-pointer text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        <span id="copy-btn-text">{t.integrationInstallBtn}</span>
      </button>
    </div>

    {/* Paths / Platforms Grid */}
    <div class="space-y-4">
      <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-500 text-left mb-6">
        {t.integrationPathsTitle}
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
        
        {/* Antigravity */}
        <div class="glass-premium cursor-glow-border rounded-2xl p-6 border border-white/5 flex gap-4 text-left hover:-translate-y-1 transition-all duration-300">
          <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center border border-primary/20 text-primary shrink-0 font-black text-sm">
            AG
          </div>
          <div>
            <h4 class="font-bold text-zinc-100 text-sm mb-1.5">Antigravity Native</h4>
            <p class="text-xs text-zinc-450 leading-relaxed text-zinc-400">{t.integrationAntigravityDesc}</p>
          </div>
        </div>

        {/* Claude */}
        <div class="glass-premium cursor-glow-border rounded-2xl p-6 border border-white/5 flex gap-4 text-left hover:-translate-y-1 transition-all duration-300">
          <div class="w-10 h-10 bg-orange-500/10 rounded-xl flex items-center justify-center border border-orange-500/20 text-orange-400 shrink-0 font-black text-sm">
            CC
          </div>
          <div>
            <h4 class="font-bold text-zinc-100 text-sm mb-1.5">Claude Code</h4>
            <p class="text-xs text-zinc-450 leading-relaxed text-zinc-400">{t.integrationClaudeDesc}</p>
          </div>
        </div>

        {/* Cursor */}
        <div class="glass-premium cursor-glow-border rounded-2xl p-6 border border-white/5 flex gap-4 text-left hover:-translate-y-1 transition-all duration-300">
          <div class="w-10 h-10 bg-indigo-500/10 rounded-xl flex items-center justify-center border border-indigo-500/20 text-indigo-400 shrink-0 font-black text-sm">
            CR
          </div>
          <div>
            <h4 class="font-bold text-zinc-100 text-sm mb-1.5">Cursor IDE</h4>
            <p class="text-xs text-zinc-450 leading-relaxed text-zinc-400">{t.integrationCursorDesc}</p>
          </div>
        </div>

        {/* Gemini */}
        <div class="glass-premium cursor-glow-border rounded-2xl p-6 border border-white/5 flex gap-4 text-left hover:-translate-y-1 transition-all duration-300">
          <div class="w-10 h-10 bg-sky-500/10 rounded-xl flex items-center justify-center border border-sky-500/20 text-sky-400 shrink-0 font-black text-sm">
            GE
          </div>
          <div>
            <h4 class="font-bold text-zinc-100 text-sm mb-1.5">Gemini CLI</h4>
            <p class="text-xs text-zinc-450 leading-relaxed text-zinc-400">{t.integrationGeminiDesc}</p>
          </div>
        </div>

      </div>
    </div>

  </div>

  <script is:inline define:vars={{ command }}>
    // Copy script
    const initIntegration = () => {
      const copyBtn = document.getElementById('copy-install-btn');
      const btnText = document.getElementById('copy-btn-text');
      
      if (copyBtn && btnText) {
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(command)
            .then(() => {
              const originalText = btnText.innerText;
              btnText.innerText = "Copied!";
              copyBtn.style.boxShadow = "0 0 30px rgba(34, 197, 94, 0.4)";
              
              setTimeout(() => {
                btnText.innerText = originalText;
                copyBtn.style.boxShadow = "";
              }, 2000);
            })
            .catch(err => {
              console.error("Failed to copy installation command:", err);
            });
        });
      }
    };
    
    initIntegration();
    document.addEventListener('astro:page-load', initIntegration);
  </script>
</section>
