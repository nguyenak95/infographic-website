---
// Placeholder for Lucide React Icons (we can also render them in React, but for Astro we can use simple SVG or a library)
---

<section class="w-full flex flex-col items-center text-center mx-auto py-12 md:py-24 px-4">
  
  <div class="flex flex-wrap items-center justify-center gap-4 mb-8 text-sm md:text-base font-semibold text-primary uppercase tracking-wider">
    <span class="bg-primary/10 text-primary px-3 py-1 rounded-full border border-primary/20">NotebookLM</span>
    <span class="text-zinc-500">+</span>
    <span class="bg-sky-500/10 text-sky-400 font-bold px-3 py-1 rounded-full border border-sky-500/20">Antigravity</span>
    <span class="text-zinc-500">+</span>
    <span class="bg-indigo-500/10 text-indigo-400 px-3 py-1 rounded-full border border-indigo-500/20">Cursor</span>
  </div>

  <h1 class="text-5xl md:text-7xl lg:text-[7.5rem] font-black leading-[1.05] tracking-tight text-foreground mb-8">
    Agentic <br/> 
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-cta">
      Infographic
    </span> <br/>
    Intelligence
  </h1>

  <p class="text-lg md:text-2xl text-foreground/70 max-w-3xl mb-12 leading-relaxed">
    A massive, searchable database of domain contexts, visual styles, and structural layouts. 
    Build beautiful, highly-customized infographics with the NotebookLM CLI.
  </p>

  <div class="flex flex-col sm:flex-row items-center gap-4 mb-20 w-full sm:w-auto">
    <a href="#how-it-works" class="w-full sm:w-auto px-8 py-4 bg-primary hover:bg-sky-400 text-white font-bold rounded-full transition-all duration-300 text-lg shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-1">
      How it Works
    </a>
    <a href="#gallery" class="w-full sm:w-auto px-8 py-4 bg-zinc-800 hover:bg-zinc-700 text-white font-bold rounded-full transition-all duration-300 text-lg border-2 border-zinc-700 hover:border-zinc-500">
      View Gallery
    </a>
  </div>

  <!-- Terminal Mockup -->
  <div class="w-full max-w-4xl bg-slate-900 rounded-2xl shadow-2xl overflow-hidden border border-slate-700/50 mb-20 text-left">
    <div class="flex items-center px-4 py-3 bg-slate-800/80 border-b border-slate-700/50">
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
      </div>
      <div class="mx-auto text-xs text-slate-400 font-mono tracking-wider">~/projects/infographics</div>
    </div>
    <div class="p-6 md:p-8 font-mono text-sm md:text-base text-slate-300">
      <div class="flex items-center gap-3 opacity-70">
        <span class="text-green-400">→</span>
        <span class="text-blue-400">infographics</span>
      </div>
      <div class="mt-2 flex items-start gap-3">
        <span class="text-primary mt-1">$</span>
        <div class="typing-animation-container text-slate-100 font-medium">
          nlm <span class="text-secondary">infographic create</span> 12a4f --confirm "SaaS Launch Timeline"
        </div>
      </div>
      <div class="mt-6 text-slate-400 animate-pulse delay-1000">
        > Extracting structure: <span class="text-purple-400">Timeline</span><br/>
        > Applying style: <span class="text-orange-400">Glassmorphism</span><br/>
        > Compiling domain context: <span class="text-sky-400">SaaS</span><br/>
        > Generating SVG...
      </div>
      <div class="mt-4 text-green-400 font-bold hidden md:block">
        ✔ Infographic generated successfully in ./output/saas_timeline.svg! 🚀
      </div>
    </div>
  </div>

  <!-- Statistics Row -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-16 w-full py-8 border-y border-zinc-800/80">
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">5</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">Domains</span>
    </div>
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">6</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">Structures</span>
    </div>
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">6</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">Styles</span>
    </div>
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">49</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">Full Templates</span>
    </div>
  </div>
</section>

<style>
  .typing-animation-container {
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid var(--color-primary);
    width: 0;
    animation: typing 3s steps(40, end) forwards, blink 1s step-end infinite;
    animation-delay: 0.5s;
  }

  @keyframes typing {
    from { width: 0 }
    to { width: 100% }
  }

  @keyframes blink {
    from, to { border-color: transparent }
    50% { border-color: var(--color-primary) }
  }
</style>
