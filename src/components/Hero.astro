---
// Hero section component for AI Agent Infographic Showcase calling NotebookLM
import { INFOGRAPHICS } from '../data/infographics';
import { TRANSLATIONS, type Language } from '../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const t = TRANSLATIONS[lang];
---

<section class="w-full flex flex-col items-center text-center mx-auto py-12 md:py-28 px-4 relative overflow-hidden">
  <!-- Futuristic Structural Cyber-Grid (Special Background Design) - Increased Opacity -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px] [mask-image:radial-gradient(ellipse_65%_55%_at_50%_35%,#000_60%,transparent_100%)] z-0 pointer-events-none"></div>

  <!-- Decorative Ambient Glow Circles / Volumetric Lighting Flare - Increased Glow + Added Multi-layered Warm/Cool Accents -->
  <div class="absolute -top-[20%] left-1/2 -translate-x-1/2 w-[1450px] h-[650px] bg-gradient-to-tr from-primary/26 via-secondary/32 to-purple-500/26 rounded-full blur-[170px] pointer-events-none z-0 transform rotate-[10deg] animate-pulse-glow"></div>
  <div class="absolute top-[10%] left-1/4 w-[750px] h-[450px] bg-gradient-to-tr from-indigo-500/20 via-purple-500/22 to-cta/18 rounded-full blur-[150px] pointer-events-none z-0 animate-pulse-glow" style="animation-delay: 1.5s;"></div>
  
  <!-- Dynamic Linear Laser Light Streaks - Increased Thickness and Luminescence -->
  <div class="absolute top-24 left-0 right-0 h-[2.5px] bg-gradient-to-r from-transparent via-primary/65 to-transparent blur-[1.5px] animate-pulse-glow z-0 pointer-events-none"></div>
  <div class="absolute top-[42%] left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-cta/40 to-transparent blur-[2.5px] z-0 pointer-events-none animate-pulse-glow" style="animation-delay: 2s;"></div>
  
  <div class="flex flex-wrap items-center justify-center gap-4 mb-8 text-sm md:text-base font-semibold text-primary uppercase tracking-wider relative z-10">
    <span class="bg-primary/10 text-primary px-3.5 py-1 rounded-full border border-primary/20">{t.heroPre}</span>
    <span class="text-zinc-500">+</span>
    <span class="bg-indigo-500/10 text-indigo-400 px-3.5 py-1 rounded-full border border-indigo-500/20">infographic-creator</span>
  </div>

  <h1 class="text-5xl md:text-7xl lg:text-[7.5rem] font-black leading-[1.05] tracking-tight text-foreground mb-8 relative z-10 drop-shadow-[0_0_45px_rgba(250,250,250,0.22)]">
    {t.heroTitlePart1} <br/> 
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-cta drop-shadow-[0_0_40px_rgba(56,189,248,0.58)]">
      {t.heroTitlePart2}
    </span> <br/>
    {t.heroTitlePart3}
  </h1>

  <p class="text-lg md:text-2xl text-foreground/70 max-w-3xl mb-12 leading-relaxed relative z-10">
    {t.heroDesc}
  </p>

  <div class="flex flex-col sm:flex-row items-center gap-4 mb-20 w-full sm:w-auto relative z-10">
    <a href="#how-it-works" class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-primary to-secondary hover:from-sky-400 hover:to-indigo-400 text-white font-bold rounded-full transition-all duration-300 text-lg shadow-[0_0_20px_rgba(14,165,233,0.25)] hover:shadow-[0_0_30px_rgba(14,165,233,0.45)] hover:-translate-y-1">
      {t.heroCtaHowItWorks}
    </a>
    <a href="#gallery" class="w-full sm:w-auto px-8 py-4 bg-zinc-950/40 hover:bg-zinc-900/60 text-white font-bold rounded-full transition-all duration-300 text-lg border border-white/10 hover:border-white/20 backdrop-blur-md">
      {t.heroCtaGallery}
    </a>
  </div>

  <!-- Agent Chat Session UI Mockup -->
  <div class="w-full max-w-4xl glass-premium rounded-3xl p-6 md:p-8 space-y-6 mb-20 text-left relative z-10">
    <!-- Inner glowing edge -->
    <div class="absolute inset-0 border border-white/5 rounded-3xl pointer-events-none"></div>

    {/* Header */}
    <div class="flex items-center justify-between border-b border-white/5 pb-4">
      <div class="flex items-center gap-3">
        <div class="w-3 h-3 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]"></div>
        <span class="text-sm font-bold text-slate-200 tracking-tight">{t.chatActiveSession}</span>
      </div>
      <span class="text-[10px] font-black uppercase tracking-widest px-3 py-1 bg-white/5 text-slate-400 rounded-lg border border-white/5 select-none">
        {t.heroPre}
      </span>
    </div>

    {/* Chat Stream */}
    <div class="space-y-6">
      
      {/* Bubble 1: User Prompt */}
      <div class="flex items-start gap-4 justify-end">
        <div class="bg-primary/10 border border-primary/20 rounded-2xl rounded-tr-none p-4 max-w-xl text-right">
          <p class="text-sm md:text-base text-zinc-200 leading-relaxed font-medium">
            {t.chatUserBubble}
          </p>
        </div>
        <div class="w-10 h-10 bg-zinc-900 border border-white/5 rounded-xl flex items-center justify-center font-bold text-zinc-400 text-xs shrink-0 select-none">
          USER
        </div>
      </div>

      {/* Skill Activation Indicator */}
      <div class="flex justify-center">
        <div class="flex items-center gap-2.5 px-4 py-1.5 bg-purple-950/40 border border-purple-500/30 text-purple-400 rounded-full text-[10px] font-black uppercase tracking-widest animate-pulse shadow-[0_0_10px_rgba(168,85,247,0.15)]">
          <span class="text-purple-400">⚡</span>
          <span>{t.chatTriggeringSkill}</span>
        </div>
      </div>

      {/* Bubble 2: AI Agent Output */}
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-primary/20 border border-primary/30 rounded-xl flex items-center justify-center font-black text-primary text-xs shrink-0 select-none">
          AI
        </div>
        <div class="bg-zinc-950/80 border border-white/5 rounded-2xl rounded-tl-none p-5 max-w-2xl flex-1 space-y-4">
          <div class="font-mono text-xs text-slate-400 space-y-2 leading-relaxed">
            <div class="flex items-center gap-2 text-green-400">
              <span class="font-bold">✔</span>
              <span>{t.chatStep1}</span>
            </div>
            <div class="flex items-center gap-2 text-purple-400">
              <span class="font-bold">✔</span>
              <span>{t.chatStep2}</span>
            </div>
            <div class="flex items-center gap-2 text-sky-400">
              <span class="font-bold">✔</span>
              <span>{t.chatStep3}</span>
            </div>
            <div class="flex items-center gap-2 text-zinc-450">
              <span class="animate-pulse text-amber-500">⚙</span>
              <span class="animate-pulse">{t.chatStep4}</span>
            </div>
          </div>
          
          {/* Preview Image */}
          <div class="mt-4 border border-white/5 rounded-2xl overflow-hidden shadow-2xl relative group bg-zinc-900/10 p-2">
            <img 
              src="/infographics/hc_001_treatment_protocol.png" 
              alt={t.chatPreviewAlt} 
              class="w-full h-auto max-h-[350px] object-contain rounded-xl"
            />
            <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center rounded-xl">
              <a href="#gallery" class="px-6 py-2.5 bg-white hover:bg-slate-100 text-slate-900 font-bold rounded-full text-xs shadow-lg hover:scale-105 transition-transform">
                {t.chatExploreLink}
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Statistics Row -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-16 w-full py-8 border-y border-zinc-800/80">
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">5</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">{t.statsDomains}</span>
    </div>
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">12</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">{t.statsStructures}</span>
    </div>
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">10+</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">{t.statsVisualStyles}</span>
    </div>
    <div class="flex flex-col items-center">
      <span class="text-4xl md:text-5xl font-black text-foreground mb-2">{INFOGRAPHICS.length}</span>
      <span class="text-sm font-semibold text-foreground/60 uppercase tracking-widest">{t.statsActiveBlueprints}</span>
    </div>
  </div>
</section>
